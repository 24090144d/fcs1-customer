# Per-customer runtime config
NODE_ENV=production
NEXT_PUBLIC_APP_NAME=FCS1 Dashboard

# Customer identity
CUSTOMER_CODE=ACME
CUSTOMER_NAME=Acme Hospitality

# Azure PostgreSQL (customer dedicated)
DATABASE_URL=postgresql://app_user:<password>@<server>.postgres.database.azure.com:5432/appdb?sslmode=require
PGHOST=<server>.postgres.database.azure.com
PGPORT=5432
PGDATABASE=appdb
PGUSER=app_user
PGPASSWORD=<password>

# Reset database protection
RESET_DB_PASSWORD=<yymmdd-or-rotated-secret>

# Optional
NEXT_PUBLIC_DEFAULT_CHAIN=
