# ─────────────────────────────────────────────────────────────────────────────
# Environment variables — copy to `.env.local` and fill real values.
# `.env.local` is gitignored; do not commit credentials.
# ─────────────────────────────────────────────────────────────────────────────

# Primary database connection (used by app runtime and API routes)
# Azure PostgreSQL example:
# DATABASE_URL=postgresql://<user>:<password>@<server>.postgres.database.azure.com:5432/<db>?sslmode=require
DATABASE_URL=

# Optional direct/unpooled connection for maintenance or migrations
# DATABASE_URL_UNPOOLED=postgresql://<user>:<password>@<server>.postgres.database.azure.com:5432/<db>?sslmode=require
DATABASE_URL_UNPOOLED=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000


